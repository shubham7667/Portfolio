# Copy this file to .env and fill in your real values. Never commit .env.

PORT=4000

# SMTP credentials used to SEND the email (the "from" mailbox).
# For Gmail: use smtp.gmail.com, port 587, and a 16-character App Password
# (Google Account -> Security -> 2-Step Verification -> App passwords).
# Your normal Gmail password will NOT work here.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=rishab.ss64@gmail.com
SMTP_PASS=dcgl kbjr wmzm fxse

# Where contact form messages should be delivered.
TO_EMAIL=rishab.ss64@gmail.com

# Restrict CORS to your deployed frontend in production, e.g.
# ALLOWED_ORIGIN=https://shubhamkumar.dev
ALLOWED_ORIGIN=*
